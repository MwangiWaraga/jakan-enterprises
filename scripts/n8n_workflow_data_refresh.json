{
  "name": "Data Refresh Orchestration",
  "nodes": [
    {
      "parameters": {},
      "name": "Start",
      "type": "n8n-nodes-base.start",
      "typeVersion": 1,
      "position": [250, 300]
    },
    {
      "parameters": {
        "command": "cd /workspace && python scripts/orchestrate_refresh.py"
      },
      "name": "Run Data Refresh",
      "type": "n8n-nodes-base.executeCommand",
      "typeVersion": 1,
      "position": [450, 300]
    },
    {
      "parameters": {
        "options": {}
      },
      "name": "Success Response",
      "type": "n8n-nodes-base.respondToWebhook",
      "typeVersion": 1,
      "position": [650, 200],
        "parameters": {
        "responseCode": "200",
        "responseData": "all"
      }
    },
    {
      "parameters": {
        "responseCode": "500",
        "responseData": "all"
      },
      "name": "Error Response",
      "type": "n8n-nodes-base.respondToWebhook",
      "typeVersion": 1,
      "position": [650, 400]
    }
  ],
  "connections": {
    "Start": {
      "main": [
        [
          {
            "node": "Run Data Refresh",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Run Data Refresh": {
      "main": [
        [
          {
            "node": "Success Response",
            "type": "main",
            "index": 0
          }
        ],
        [
          {
            "node": "Error Response",
            "type": "main",
            "index": 0
          }
        ]
      ]
    }
  },
  "active": true,
  "settings": {
    "executionOrder": "v1"
  }
}
